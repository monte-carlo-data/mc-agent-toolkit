{
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "python3 ${CODEX_PLUGIN_ROOT}/hooks/prevent/bash_hook.py"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "python3 ${CODEX_PLUGIN_ROOT}/hooks/prevent/turn_end_hook.py"
                    }
                ]
            }
        ]
    }
}
