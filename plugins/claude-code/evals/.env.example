# Anthropic API key — used by both the agent (claude-agent-sdk) and the LLM judge
# Create one at https://platform.claude.com/settings/keys
ANTHROPIC_API_KEY=

# Monte Carlo dev MCP credentials (live evals with ENV=dev)
# Used against mcp.dev.getmontecarlo.com
# Create one at https://app.dev.getmontecarlo.com/settings/api (MCP server key)
MCD_ID_DEV=
MCD_TOKEN_DEV=

# Monte Carlo prod MCP credentials (live evals with ENV=prod)
# Used against mcp.getmontecarlo.com
# Create one at https://app.getmontecarlo.com/settings/api (MCP server key)
MCD_ID=
MCD_TOKEN=
