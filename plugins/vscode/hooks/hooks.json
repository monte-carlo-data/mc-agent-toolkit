{
    "hooks": {
        "PreToolUse": [
            {
                "type": "command",
                "command": "python3 hooks/prevent/pre_edit_hook.py",
                "matcher": "editFiles|createFile",
                "timeout": 5
            },
            {
                "type": "command",
                "command": "python3 hooks/prevent/pre_commit_hook.py",
                "matcher": "runTerminalCommand",
                "timeout": 5
            }
        ],
        "PostToolUse": [
            {
                "type": "command",
                "command": "python3 hooks/prevent/post_edit_hook.py",
                "matcher": "editFiles|createFile",
                "timeout": 3
            }
        ],
        "Stop": [
            {
                "type": "command",
                "command": "python3 hooks/prevent/turn_end_hook.py"
            }
        ]
    }
}
